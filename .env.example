# Your Windows username (run `echo %USERNAME%` in CMD to find it).
# Used to mount C:\Users\<you>\.claude into the container for persistent login.
WINDOWS_USERNAME=YourWindowsUsername

# Only needed if using Anthropic Console/API access instead of a Claude subscription.
# Leave commented out if you log in via browser (Pro/Max/Team/Enterprise).
# ANTHROPIC_API_KEY=sk-ant-...
