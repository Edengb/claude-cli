# Path to your home directory on the host machine.
# Used to mount your .claude credentials into the container for persistent login.
#
# Windows (Docker Desktop maps C:\Users\<you> to /c/Users/<you> in the Linux VM):
#   CLAUDE_HOME=/c/Users/YourWindowsUsername
#
# macOS:
#   CLAUDE_HOME=/Users/yourusername
#
# Linux:
#   CLAUDE_HOME=/home/yourusername
CLAUDE_HOME=/c/Users/YourWindowsUsername

# Only needed if using Anthropic Console/API access instead of a Claude subscription.
# Leave commented out if you log in via browser (Pro/Max/Team/Enterprise).
# ANTHROPIC_API_KEY=sk-ant-...
